<?xml version="1.0" encoding="utf-8"?>
<!--
    FileProvider paths for sharing downloaded attachments with external viewers.
    Matches the storage tree used by MediaStorageHelper:
      /storage/emulated/0/Android/media/<package>/JippyTalk/{sent,received}/
    Plus internal files dir as a fallback.
-->
<paths>
    <external-media-path
        name="external_media"
        path="." />
    <files-path
        name="internal_files"
        path="." />
    <cache-path
        name="internal_cache"
        path="." />
</paths>
