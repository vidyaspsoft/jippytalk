<?xml version="1.0" encoding="utf-8"?>
<!-- Received media message: images, PDFs, documents (shows thumbnail + file name) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/llReceivedMediaMessage"
    android:orientation="vertical"
    android:layout_marginTop="6dp"
    android:longClickable="true"
    android:clickable="true"
    android:focusable="true"
    android:background="?android:attr/selectableItemBackground">

    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardCornerRadius="40dp"
        style="@style/cardViewBackground"
        android:id="@+id/cvDateDisplay"
        android:visibility="gone">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:id="@+id/tvDateDisplay"
            android:gravity="center"
            android:textAlignment="center"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"
            android:textAppearance="@style/TextAppearance.AppCompat.Small" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:id="@+id/llMessageOverview">

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="80dp"
            android:id="@+id/cvMediaContainer"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="150dp"
                android:orientation="vertical"
                android:background="@drawable/received_message_background">

                <!-- WhatsApp-style document card (receiver side). -->
                <LinearLayout
                    android:id="@+id/llDocumentPill"
                    android:layout_width="260dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <!-- Thumbnail preview (visible for PDFs with rendered first page) -->
                    <ImageView
                        android:id="@+id/ivDocThumbnail"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:contentDescription="@string/todo" />

                    <!-- Horizontal pill row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="#22000000"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/ivDocIcon"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_document"
                            android:contentDescription="@string/todo" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDocName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxLines="2"
                            android:ellipsize="middle"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            style="@style/messagesTextStyle"
                            tools:text="FileTransfer.postman_collection.json" />

                        <TextView
                            android:id="@+id/tvDocSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:maxLines="1"
                            android:textSize="11sp"
                            style="@style/messagesIconsStyle"
                            tools:text="18 KB · JSON" />
                    </LinearLayout>

                    <!-- Download button shown inline when the file hasn't been
                         downloaded yet. Tapping kicks off mediaTransferManager.downloadAttachment. -->
                    <ImageView
                        android:id="@+id/ivPillDownload"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_download"
                        android:visibility="gone"
                        app:tint="?attr/colorPrimary"
                        android:contentDescription="@string/todo" />

                    <!-- WhatsApp-style circular download progress: a determinate
                         ring around a centered "%" number. Visibility on the
                         FrameLayout drives both children. The percentage is
                         pushed in by MessageAdapter.onBindViewHolder's PROGRESS
                         payload branch (state.getProgress()). -->
                    <FrameLayout
                        android:id="@+id/flPillDownloadProgress"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:layout_gravity="center_vertical"
                        android:visibility="gone">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/pbPillDownload"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:indicatorColor="?attr/colorPrimary"
                            app:indicatorSize="36dp"
                            app:trackColor="@android:color/darker_gray"
                            app:trackThickness="3dp"
                            android:max="100"
                            android:indeterminate="false" />

                        <TextView
                            android:id="@+id/tvPillDownloadProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            tools:text="42%" />
                    </FrameLayout>
                </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/flMediaPreviewContainer"
                    android:layout_width="250dp"
                    android:layout_height="200dp">

                    <ImageView
                        android:id="@+id/ivMediaPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="@string/attachment_gallery" />

                    <!-- Download button overlay -->
                    <FrameLayout
                        android:id="@+id/flDownloadOverlay"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#80000000"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/ivDownload"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_download"
                            android:contentDescription="@string/todo" />
                    </FrameLayout>

                    <!-- Download progress overlay -->
                    <FrameLayout
                        android:id="@+id/flDownloadProgressOverlay"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#80000000"
                        android:visibility="gone">

                        <ProgressBar
                            android:id="@+id/progressBarDownload"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="24dp"
                            android:layout_marginEnd="24dp"
                            android:max="100"
                            android:progress="0" />
                    </FrameLayout>

                    <!-- Retry overlay: shown on download failure -->
                    <FrameLayout
                        android:id="@+id/flRetryOverlay"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#80000000"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/ivRetryDownload"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_retry"
                            android:contentDescription="@string/todo" />
                    </FrameLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvFileName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="5dp"
                    android:maxLines="1"
                    android:ellipsize="middle"
                    android:fontFamily="sans-serif"
                    android:textSize="13sp"
                    android:visibility="gone"
                    style="@style/messagesTextStyle" />

                <TextView
                    android:id="@+id/tvCaption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="5dp"
                    android:fontFamily="sans-serif"
                    style="@style/messagesTextStyle" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end|center"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_marginEnd="5dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="3dp">

                    <ImageView
                        android:layout_width="@dimen/extra_small_text_size"
                        android:layout_height="@dimen/extra_small_text_size"
                        android:id="@+id/ivStarImage"
                        android:visibility="gone"
                        android:src="@drawable/ic_baseline_stars_24"
                        android:layout_marginEnd="5dp"
                        android:contentDescription="@string/todo"
                        style="@style/messagesIconsStyle" />

                    <TextView
                        android:id="@+id/tvMessageTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="02:30 AM"
                        android:fontFamily="sans-serif"
                        android:layout_marginEnd="5dp"
                        style="@style/messagesIconsStyle"
                        android:textSize="@dimen/extra_small_text_size" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</LinearLayout>
