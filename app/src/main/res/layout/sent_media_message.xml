<?xml version="1.0" encoding="utf-8"?>
<!-- Sent media message: images, PDFs, documents (shows thumbnail + file name) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/llSentMediaMessage"
    android:orientation="vertical"
    android:layout_marginTop="6dp"
    android:longClickable="true"
    android:clickable="true"
    android:focusable="true"
    android:background="?android:attr/selectableItemBackground">

    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardCornerRadius="40dp"
        style="@style/cardViewBackground"
        android:id="@+id/cvDateDisplay"
        android:visibility="gone"
        tools:visibility="visible">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:id="@+id/tvDateDisplay"
            android:gravity="center"
            android:textAlignment="center"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"
            android:textAppearance="@style/TextAppearance.AppCompat.Small" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:id="@+id/llMessageOverview">

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginStart="80dp"
            android:layout_marginEnd="10dp"
            android:id="@+id/cvMediaContainer"
            app:cardUseCompatPadding="true"
            style="@style/senderMessageTheme">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="150dp"
                android:orientation="vertical"
                android:id="@+id/llMediaBackground">

                <!-- WhatsApp-style document card. Shows thumbnail at top when
                     available (e.g. PDF first page), then pill row below. -->
                <LinearLayout
                    android:id="@+id/llDocumentPill"
                    android:layout_width="260dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <!-- Thumbnail preview (visible for PDFs with rendered first page) -->
                    <ImageView
                        android:id="@+id/ivDocThumbnail"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:contentDescription="@string/todo" />

                    <!-- Horizontal pill row: icon + name + size -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="#33FFFFFF"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/ivDocIcon"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_document"
                            android:contentDescription="@string/todo" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDocName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxLines="2"
                            android:ellipsize="middle"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            style="@style/messagesTextStyle"
                            tools:text="FileTransfer.postman_collection.json" />

                        <TextView
                            android:id="@+id/tvDocSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:maxLines="1"
                            android:textSize="11sp"
                            style="@style/messagesIconsStyle"
                            tools:text="18 KB · JSON" />
                    </LinearLayout>

                    <!-- Upload progress spinner (visible during S3 upload) -->
                    <ProgressBar
                        android:id="@+id/pbPillUpload"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginStart="8dp"
                        android:indeterminateTint="?attr/colorPrimary"
                        android:visibility="gone" />

                    <!-- Retry icon (visible on upload failure) -->
                    <ImageView
                        android:id="@+id/ivPillRetry"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_retry"
                        android:visibility="gone"
                        app:tint="#D32F2F"
                        android:contentDescription="@string/todo" />
                </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/flMediaPreviewContainer"
                    android:layout_width="250dp"
                    android:layout_height="200dp">

                    <ImageView
                        android:id="@+id/ivMediaPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="@string/attachment_gallery" />

                    <!-- Upload overlay: progress + cancel + retry -->
                    <FrameLayout
                        android:id="@+id/flUploadOverlay"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#80000000"
                        android:visibility="gone">

                        <ProgressBar
                            android:id="@+id/progressBarUpload"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="24dp"
                            android:layout_marginEnd="24dp"
                            android:max="100"
                            android:progress="0" />

                        <ImageView
                            android:id="@+id/ivCancelUpload"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="8dp"
                            android:src="@drawable/ic_cancel"
                            android:contentDescription="@string/todo" />
                    </FrameLayout>

                    <!-- Retry overlay: shown on upload failure -->
                    <FrameLayout
                        android:id="@+id/flRetryOverlay"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#80000000"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/ivRetryUpload"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_retry"
                            android:contentDescription="@string/todo" />
                    </FrameLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvFileName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="5dp"
                    android:maxLines="1"
                    android:ellipsize="middle"
                    android:fontFamily="sans-serif"
                    android:textSize="13sp"
                    android:visibility="gone"
                    style="@style/messagesTextStyle" />

                <TextView
                    android:id="@+id/tvCaption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="5dp"
                    android:fontFamily="sans-serif"
                    style="@style/messagesTextStyle" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end|center"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_marginEnd="5dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="3dp">

                    <ImageView
                        android:layout_width="@dimen/extra_small_text_size"
                        android:layout_height="@dimen/extra_small_text_size"
                        android:id="@+id/ivStarImage"
                        android:visibility="gone"
                        android:src="@drawable/ic_baseline_stars_24"
                        android:layout_marginEnd="5dp"
                        android:contentDescription="@string/todo"
                        style="@style/messagesIconsStyle" />

                    <ImageView
                        android:layout_width="@dimen/extra_small_text_size"
                        android:layout_height="@dimen/extra_small_text_size"
                        android:id="@+id/ivSeenImage"
                        android:src="@drawable/ic_baseline_visibility_off_24"
                        android:layout_marginEnd="5dp"
                        android:contentDescription="@string/todo"
                        style="@style/messagesIconsStyle" />

                    <TextView
                        android:id="@+id/tvMessageTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="02:30 AM"
                        android:fontFamily="sans-serif"
                        android:layout_marginEnd="5dp"
                        style="@style/messagesIconsStyle"
                        android:textSize="@dimen/extra_small_text_size" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</LinearLayout>
