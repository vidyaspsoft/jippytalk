<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    style="@style/activity_bg3"
    tools:context=".Messages.MessagingActivity"
    >

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/transparent"
        android:id="@+id/appBar"
        >

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            >

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/ivBackArrow"
            android:src="@drawable/ic_baseline_arrow_back_ios_new_24"
            android:layout_centerVertical="true"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="2dp"
            android:contentDescription="@string/todo"
             />

        <androidx.cardview.widget.CardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="15dp"
            android:layout_marginStart="8dp"
            android:layout_centerVertical="true"
            android:id="@+id/cvProfileImage"
            android:layout_toEndOf="@id/ivBackArrow"
            >

        <ImageView
            android:id="@+id/ivProfileImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerVertical="true"
            android:scaleType="centerCrop"
            android:src="@drawable/no_profile"
            android:contentDescription="@string/todo"
            />

    </androidx.cardview.widget.CardView>

    <com.google.android.material.appbar.MaterialToolbar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/message_activity_menu"
        android:layout_alignParentEnd="true"
        android:id="@+id/toolbar"
        app:title=""
        app:popupTheme="@style/menuStyle"
        style="@style/messagingActivityTheme"
        android:layout_toEndOf="@id/cvProfileImage"
        >

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="start">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/toolbarTitle"
                tools:text="Annayya"
                android:maxLines="1"
                android:textStyle="bold"
                android:ellipsize="end"
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/toolbarSubtitle"
                tools:text="last seen at 10:00 PM"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:singleLine="true"
                android:scrollHorizontally="true"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:visibility="gone"
                />

        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>

    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="5dp"
        android:id="@+id/lluserBusy"
        android:visibility="gone"
        tools:visibility="visible"
        android:background="@color/transparent"
        >

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/alert"
            android:id="@+id/alert1"
            android:stateListAnimator="@anim/blink"
            android:contentDescription="@string/todo"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/user_is_busy"
            android:id="@+id/tvUserBusy"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:stateListAnimator="@anim/blink"
            />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/alert"
            android:id="@+id/alert2"
            android:stateListAnimator="@anim/blink"
            android:contentDescription="@string/todo" />

    </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/ivChatWallpaper"
        android:contentDescription="@string/todo"
        android:scaleType="centerCrop"
        android:src="@drawable/chat_screen_bg"
        android:layout_below="@id/appBar"
        android:adjustViewBounds="true"
        />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChats"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="5dp"
        android:layout_below="@id/appBar"
        android:layout_above="@id/rlDown"
        tools:listitem="@layout/messages_layout"
        android:scrollbars="vertical"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:clickable="true"
        android:longClickable="true"
        android:visibility="gone"
        tools:visibility="visible"
       />

    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="10dp"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="25dp"
        android:layout_marginBottom="25dp"
        android:layout_above="@id/rlDown"
        android:id="@+id/cvDownButton"
        android:visibility="gone"
        tools:visibility="visible"
        style="@style/cardViewBackground"
        >

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/baseline_arrow_downward_24"
            android:contentDescription="@string/todo"
            android:layout_margin="5dp"
            />

    </androidx.cardview.widget.CardView>


    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        android:layout_gravity="center"
        android:layout_marginTop="50dp"
        android:layout_marginStart="25dp"
        android:layout_marginEnd="25dp"
        android:layout_marginBottom="25dp"
        android:visibility="gone"
        app:strokeWidth="0dp"
        android:id="@+id/cvStartChat"
        android:layout_below="@id/appBar"
        style="@style/cardViewBackground"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            >

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="20dp"
                android:src="@drawable/emtpy_chat"
                android:contentDescription="@string/todo"
                />


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:layout_marginStart="25dp"
                android:layout_marginEnd="25dp"
                android:text="@string/make_first_move"
                android:gravity="center"
                style="@style/updatedTextColor"
                android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:id="@+id/cvSendHey"
                app:cardCornerRadius="15dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:layout_gravity="center"
                style="@style/cvMessageRequestTextBg"
                >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/make_the_first_move"
                    android:layout_margin="15dp"
                    />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/rlUnknownMsg"
        android:visibility="gone"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="10dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:elevation="10dp"
       >

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="10dp"
            app:cardUseCompatPadding="true"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/unknown_message"
                    android:layout_gravity="center"
                    android:fontFamily="@font/helvetica"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="5dp"
                    />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"
                    android:layout_marginTop="10dp">

    <androidx.cardview.widget.CardView
        android:layout_width="150dp"
        android:layout_height="35dp"
        app:cardCornerRadius="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="5dp"
        android:layout_marginTop="5dp"
        android:id="@+id/cvDeclineChat"
        app:cardBackgroundColor="#F44336">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/decline"
            android:fontFamily="@font/helvetica"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="3dp"
            android:layout_gravity="center"
            android:textColor="@color/white"
            />

    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="150dp"
        android:layout_height="35dp"
        app:cardCornerRadius="20dp"
        android:layout_marginBottom="5dp"
        android:layout_marginTop="5dp"
        android:id="@+id/cvAcceptChat"
        app:cardBackgroundColor="#1892F3"
        >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/accept"
            android:fontFamily="@font/helvetica"
            android:layout_gravity="center"
            android:layout_marginBottom="3dp"
            android:layout_marginTop="3dp"
            android:textColor="@color/white"
            />

    </androidx.cardview.widget.CardView>

    </LinearLayout>

    </LinearLayout>

    </androidx.cardview.widget.CardView>

    </RelativeLayout>


    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/rlDown"
        android:visibility="visible"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="5dp"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            >

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardCornerRadius="15dp"
            android:layout_marginEnd="5dp"
            android:layout_marginStart="10dp"
            style="@style/send_message_box"
            android:id="@+id/cvMessageTextBox"
            app:strokeWidth="1dp"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:id="@+id/llEtBox">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cvMsgToMsgReply"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    tools:visibility="gone"
                    app:cardBackgroundColor="#2F3A4D"
                    app:cardCornerRadius="10dp"
                    app:cardUseCompatPadding="true"
                    >

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:maxHeight="80dp"
                        >

                        <TextView
                            android:id="@+id/msgSenderName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_marginTop="5dp"
                            android:fontFamily="@font/roboto"
                            tools:text="You"
                            android:textColor="@color/white" />

                        <TextView
                            android:id="@+id/tvselectedMsg"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxHeight="50dp"
                            android:layout_below="@id/msgSenderName"
                            android:layout_marginStart="10dp"
                            android:layout_marginTop="5dp"
                            android:layout_marginBottom="10dp"
                            android:fontFamily="@font/roboto"
                            android:text="@string/unknown_message"
                            android:textColor="@color/white" />

                        <ImageView
                            android:id="@+id/ivClearBtn"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_marginTop="5dp"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="@string/todo"
                            android:src="@drawable/outline_clear_24" />

                    </RelativeLayout>

                </androidx.cardview.widget.CardView>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/rlEtMessage">

                    <EditText
                        android:id="@+id/etMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginEnd="10dp"
                        android:maxLines="5"
                        android:inputType="textMultiLine"
                        android:scrollbars="vertical"
                        android:overScrollMode="always"
                        android:autofillHints=""
                        android:background="@drawable/edit_bg"
                        android:fontFamily="@font/roboto"
                        android:gravity="center_vertical"
                        android:hint="@string/send_message"
                        android:padding="15dp"
                        />

                </RelativeLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:cardCornerRadius="15dp"
            android:layout_gravity="bottom"
            android:layout_marginBottom="5dp"
            android:layout_marginEnd="10dp"
            style="@style/send_message_box"
            app:strokeWidth="1dp"
            android:id="@+id/cvSendButton"
            >

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/round_send_24"
                style="@style/vectorIconsTint"
                android:layout_gravity="center"
                android:contentDescription="@string/todo"
                />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</RelativeLayout>

</RelativeLayout>



